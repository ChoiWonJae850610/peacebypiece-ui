# dependencies
/node_modules/
cloudflare/pdf-generator-worker/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage/

# production / build
/.next/
out/
build/
*.tsbuildinfo
next-env.d.ts

# env / secrets
.env
.env.*
!.env.example

# local Vercel
.vercel/

# local Cloudflare worker state
cloudflare/pdf-generator-worker/.wrangler/

# misc
.DS_Store
Thumbs.db

# local logs / temporary files
logs/
*.log
build-log*.txt
git-log*.txt
fail-reason.txt
null

# local automation / patch pipeline
incoming_patch/
processed_patch/
failed_patch/
backup/
backups/
commit-meta.md
tools/pipeline/peacebypiece-auto-pipeline-patch-*.ps1
tools/pipeline/peacebypiece-auto-pipeline-v*.ps1
tools/pipeline/peacebypiece-auto-pipeline*.bak.ps1
tools/pipeline/peacebypiece-auto-pipeline*.tmp.ps1
tools/pipeline/peacebypiece-auto-pipeline*-copy*.ps1
!tools/pipeline/peacebypiece-auto-pipeline.ps1

# generated scan files
git-status.txt
git-tracked-files.txt
git-history-files.txt
repo-state-*.txt

# local build failure logs / patch result artifacts
FAIL_*_build*.txt
build-*.txt
patch_result/

# archives
*.zip
*.7z
*.rar
*.tgz

# secret/key files
*.pem
*.key
*.p12
*.pfx
service-account*.json
credentials*.json
# local generated demo files
.tmp/
