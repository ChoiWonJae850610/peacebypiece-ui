{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "strict": false,
    "baseUrl": ".",
    "paths": {"@/*": ["./*"]},
    "allowJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"]
  },
  "include": ["app/**/*.tsx", "components/**/*.tsx"]
}
