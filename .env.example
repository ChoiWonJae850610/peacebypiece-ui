# Neon / Postgres connection string
# Copy this file to .env.local and paste your real connection string.
# Supported keys in the app: DATABASE_URL, POSTGRES_URL, POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING, NEON_DATABASE_URL

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Partner repository mode: mock | db
PARTNER_REPOSITORY_MODE=db

# Attachment / Memo repository mode: mock | db
ATTACHMENT_MEMO_REPOSITORY_MODE=db

# Cloudflare R2 object storage
# Never commit real values. Keep secrets only in .env.local / Vercel Environment Variables.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=peacebypiece-files
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com

# Cloudflare Worker upload/read fallback for restricted R2 S3 endpoint environments
# Use the deployed Worker root URL. The same Worker handles PUT upload and GET preview/download.
# R2_WORKER_UPLOAD_URL=https://your-worker.your-domain.workers.dev
# R2_WORKER_UPLOAD_SECRET=replace-with-long-random-shared-secret

# Google OAuth for WAFL invitation/member login
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
# Optional. If omitted, the app derives /api/auth/google/callback from the current origin.
GOOGLE_OAUTH_REDIRECT_URI=""

# WAFL auth session signing
# Use a long random value in .env.local / Vercel Environment Variables.
WAFL_SESSION_SECRET=""
