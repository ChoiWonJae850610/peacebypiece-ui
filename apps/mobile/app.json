{
  "expo": {
    "owner": "lostab",
    "name": "WAFL",
    "slug": "wafl-mobile",
    "version": "2.0.0",
    "scheme": "wafl",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wafl.app",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wafl.app",
      "adaptiveIcon": {
        "backgroundColor": "#f3eee4"
      }
    },
    "extra": {
      "appVersion": "2.0.0-alpha.53",
      "mockOnly": false,
      "dataMode": "dev-test-tailscale-auto-connect",
      "router": {},
      "eas": {
        "projectId": "6cc3b260-a2cc-4c97-9c15-764bda530836"
      }
    }
  }
}
